<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#6200EA">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">
            <Button
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="← Back"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9C27B0"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁️ Who Can Monitor Me"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage your watchers"
                    android:textSize="12sp"
                    android:textColor="#CE93D8"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- WATCHER COUNT BANNER -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#EDE7F6">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ️ Your Privacy"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#4A148C"/>
            <TextView
                android:id="@+id/watcherCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading…"
                android:textSize="14sp"
                android:textColor="#6200EA"
                android:layout_marginTop="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You can remove anyone from this list at any time. They will need to send a new request and you will need to accept again."
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- EMPTY STATE -->
    <TextView
        android:id="@+id/emptyWatchersText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nobody is monitoring you yet.\n\nWhen someone accepts their request\nto monitor you, they will appear here."
        android:textSize="14sp"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- WATCHERS LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/watchersRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"/>

</LinearLayout>