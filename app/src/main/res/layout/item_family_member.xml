<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp" app:cardElevation="3dp">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp"
        android:background="#FFFFFF">
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView
                android:id="@+id/memberName"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp" android:textStyle="bold" android:textColor="#212121"/>
            <TextView
                android:id="@+id/memberBattery"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#757575"/>
        </LinearLayout>
        <TextView
            android:id="@+id/memberPhone"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="#9E9E9E" android:layout_marginTop="2dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>
        <TextView
            android:id="@+id/memberActivity"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="15sp" android:textStyle="bold"/>
        <TextView
            android:id="@+id/memberLastSeen"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#BDBDBD" android:layout_marginTop="4dp"/>
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="12dp">
            <Button
                android:id="@+id/memberCallButton"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1"
                android:text="📞 Call" android:textSize="13sp"
                android:textColor="#FFFFFF" android:backgroundTint="#2196F3"
                android:layout_marginEnd="8dp"/>
            <Button
                android:id="@+id/memberRemoveButton"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Remove" android:textSize="13sp"
                android:textColor="#FFFFFF" android:backgroundTint="#9E9E9E"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>