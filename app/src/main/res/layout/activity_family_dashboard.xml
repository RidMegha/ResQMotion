<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#6200EA">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">
            <Button
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="← Back"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9C27B0"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👨‍👩‍👧 Family Monitoring"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="10dp"/>
            <Button
                android:id="@+id/viewRequestsButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🔔 Requests"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E91E63"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- PENDING BADGE -->
    <TextView
        android:id="@+id/pendingBadge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9C4"
        android:padding="10dp"
        android:text=""
        android:textSize="13sp"
        android:textColor="#F57F17"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- MY OWN STATUS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#E8F5E9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 My Status"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#C8E6C9"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/myStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○ Not monitoring"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#757575"/>
                    <TextView
                        android:id="@+id/myActivityText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start monitoring on the main screen"
                        android:textSize="14sp"
                        android:textColor="#424242"
                        android:layout_marginTop="4dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:id="@+id/myConfidenceText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="12sp"
                            android:textColor="#757575"/>
                        <TextView
                            android:id="@+id/myBatteryText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#757575"/>
                    </LinearLayout>

                    <!-- WHO CAN MONITOR ME button — sits inside My Status card -->
                    <Button
                        android:id="@+id/myWatchersButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="👁️ Who Can Monitor Me"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#5C6BC0"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- FAMILY SECTION HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="👨‍👩‍👧 Monitoring (max 5)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>
                <Button
                    android:id="@+id/addFamilyButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Add Member"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4CAF50"/>
            </LinearLayout>

            <!-- EMPTY STATE -->
            <TextView
                android:id="@+id/emptyFamilyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No family members added yet.\n\nTap '+ Add Member' to start\nmonitoring your loved ones."
                android:textSize="14sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:padding="32dp"/>

            <!-- FAMILY RECYCLER LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/familyRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

            <View android:layout_width="match_parent" android:layout_height="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>